---
// HeroCanvas.astro — Animated particle glow hero with canvas
---

<section class="hero-section" id="hero">
  <canvas id="hero-canvas" aria-hidden="true"></canvas>

  <div class="hero-content">
    <div class="hero-badge">
      <span>⚡</span>
      <span>Open Source · Zero Trust · v1.2</span>
    </div>

    <h1 class="hero-title">Antimatter</h1>

    <p class="hero-subtitle">
      The open-source bridge that connects your phone to your local AI agents.<br />
      Monitor, prompt, and control from anywhere — secured by enterprise-grade cryptography.
    </p>

    <div class="badge-row">
      <a href="https://f-droid.org/packages/dev.saifmukhtar.antimatter/" target="_blank" rel="noopener">
        <img src="https://img.shields.io/badge/F--Droid-1.2.0-3DDC84?style=flat-square&logo=fdroid&logoColor=white" alt="F-Droid" />
      </a>
      <a href="https://github.com/saifmukhtar/antimatter/releases" target="_blank" rel="noopener">
        <img src="https://img.shields.io/github/v/release/saifmukhtar/antimatter?style=flat-square&logo=github&color=6366f1" alt="GitHub Release" />
      </a>
      <a href="https://github.com/saifmukhtar/antimatter/stargazers" target="_blank" rel="noopener">
        <img src="https://img.shields.io/github/stars/saifmukhtar/antimatter?style=flat-square&logo=github&color=f59e0b" alt="Stars" />
      </a>
      <a href="https://github.com/saifmukhtar/antimatter/blob/main/LICENSE" target="_blank" rel="noopener">
        <img src="https://img.shields.io/badge/License-MIT-22D3EE?style=flat-square" alt="MIT License" />
      </a>
    </div>

    <div class="hero-actions">
      <a href="/getting-started" class="btn-primary">
        🚀 Get Started
      </a>
      <a href="https://github.com/saifmukhtar/antimatter" target="_blank" rel="noopener" class="btn-secondary">
        ⭐ GitHub
      </a>
      <a href="/android" class="btn-secondary">
        📱 Android App
      </a>
    </div>

    <div class="typing-wrapper" aria-hidden="true">
      <div style="background:rgba(0,0,0,0.6);border:1px solid rgba(59,130,246,0.3);border-radius:10px;padding:0.8rem 1.2rem;display:inline-block;font-family:'JetBrains Mono',monospace;font-size:0.85rem;">
        <span style="color:#94a3b8">$</span>
        <span id="hero-typing" style="color:#4ade80;margin-left:0.4rem"></span>
        <span id="hero-cursor" style="color:#4ade80">▋</span>
      </div>
    </div>
  </div>
</section>

<script>
// ── Particle canvas ────────────────────────────────────────────
const canvas = document.getElementById('hero-canvas') as HTMLCanvasElement;
if (canvas) {
  const ctx = canvas.getContext('2d')!;
  let W = 0, H = 0, particles: Particle[] = [];

  interface Particle {
    x: number; y: number; vx: number; vy: number;
    radius: number; alpha: number; color: string;
  }

  const COLORS = ['rgba(59,130,246,', 'rgba(34,211,238,', 'rgba(99,102,241,'];

  let isLightMode = document.documentElement.getAttribute('data-theme') === 'light';
  const observer = new MutationObserver(() => {
    isLightMode = document.documentElement.getAttribute('data-theme') === 'light';
  });
  observer.observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme'] });

  function resize() {
    W = canvas.offsetWidth; H = canvas.offsetHeight;
    canvas.width = W * devicePixelRatio; canvas.height = H * devicePixelRatio;
    ctx.scale(devicePixelRatio, devicePixelRatio);
  }

  function spawn(): Particle {
    const c = COLORS[Math.floor(Math.random() * COLORS.length)];
    return {
      x: Math.random() * W, y: Math.random() * H,
      vx: (Math.random() - 0.5) * 0.4, vy: (Math.random() - 0.5) * 0.4,
      radius: Math.random() * 2.5 + 0.5,
      alpha: Math.random() * 0.5 + 0.1,
      color: c,
    };
  }

  function init() { resize(); particles = Array.from({ length: 80 }, spawn); }

  function draw() {
    ctx.clearRect(0, 0, W, H);
    // Draw connections
    for (let i = 0; i < particles.length; i++) {
      for (let j = i + 1; j < particles.length; j++) {
        const dx = particles[i].x - particles[j].x;
        const dy = particles[i].y - particles[j].y;
        const d = Math.sqrt(dx*dx + dy*dy);
        if (d < 100) {
          ctx.beginPath();
          const baseAlpha = 0.08;
          const alphaMultiplier = isLightMode ? 3.0 : 1.0;
          ctx.strokeStyle = `rgba(59,130,246,${baseAlpha * alphaMultiplier * (1 - d/100)})`;
          ctx.lineWidth = isLightMode ? 1.0 : 0.5;
          ctx.moveTo(particles[i].x, particles[i].y);
          ctx.lineTo(particles[j].x, particles[j].y);
          ctx.stroke();
        }
      }
    }
    // Draw particles
    for (const p of particles) {
      ctx.beginPath();
      const alphaMultiplier = isLightMode ? 2.0 : 1.0;
      const grad = ctx.createRadialGradient(p.x, p.y, 0, p.x, p.y, p.radius * 3);
      grad.addColorStop(0, `${p.color}${Math.min(1, p.alpha * alphaMultiplier)})`);
      grad.addColorStop(1, `${p.color}0)`);
      ctx.fillStyle = grad;
      ctx.arc(p.x, p.y, p.radius * 3, 0, Math.PI * 2);
      ctx.fill();

      p.x += p.vx; p.y += p.vy;
      if (p.x < 0) p.x = W; if (p.x > W) p.x = 0;
      if (p.y < 0) p.y = H; if (p.y > H) p.y = 0;
    }
    requestAnimationFrame(draw);
  }

  window.addEventListener('resize', resize);
  init(); draw();
}

// ── Typing animation ───────────────────────────────────────────
const el = document.getElementById('hero-typing');
const cursor = document.getElementById('hero-cursor');
const lines = [
  'antimatter-gateway start',
  'antimatter-gateway pair',
  '✓ Tunnel: wss://antimatter.yourdomain.com',
  '✓ Ed25519 handshake complete',
  '~ $',
];

let lineIdx = 0, charIdx = 0, deleting = false, wait = 0;

function tick() {
  if (!el) return;
  const line = lines[lineIdx];
  if (!deleting) {
    charIdx++;
    el.textContent = line.slice(0, charIdx);
    if (charIdx === line.length) { deleting = true; wait = 80; }
  } else {
    wait--;
    if (wait > 0) { setTimeout(tick, 35); return; }
    charIdx--;
    el.textContent = line.slice(0, charIdx);
    if (charIdx === 0) { deleting = false; lineIdx = (lineIdx + 1) % lines.length; }
  }
  setTimeout(tick, deleting ? 28 : 65);
}

// Cursor blink
if (cursor) setInterval(() => { cursor.style.opacity = cursor.style.opacity === '0' ? '1' : '0'; }, 500);
setTimeout(tick, 800);
</script>
